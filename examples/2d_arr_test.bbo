arr[3][3];

output "\nEnter array elements (3x3) \n";

i = 0;
while(i < 3) {
    j = 0;
    while (j < 3) {
    	output "Enter element : ";
    	input arr[i][j];
    	j = j + 1
    };
    i = i + 1
};

output "\nArray:\n";
i = 0;

while(i < 3) {
    j = 0;
    while (j < 3) {
        output arr[i][j] + " ";
        j = j + 1
    };
    output "\n";
    i = i + 1
}
